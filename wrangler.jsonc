{
  // Cloudflare Worker mit Static Assets (NICHT Pages).
  // Die statische Astro-Ausgabe in ./dist wird als Assets vom Worker ausgeliefert.
  // Cloudflare Workers Builds führt automatisch `npm run build` aus und deployt anschließend.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ideenwerkstatt",
  "compatibility_date": "2025-06-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  }
}
