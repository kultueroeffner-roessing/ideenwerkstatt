---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import ProtokollCard from "../../components/ProtokollCard.astro";

const protokolle = (await getCollection("protokolle")).sort(
  (a, b) => b.data.datum.getTime() - a.data.datum.getTime(),
);
---

<Base
  title="Protokolle"
  description="Nachlese der vergangenen Ideen- und Zukunftswerkstätten in Rössing."
>
  <section class="mx-auto max-w-6xl px-5 pt-14 pb-10">
    <span class="badge badge-soft badge-info badge-lg gap-2 font-bold">
      📒 Nachlese
    </span>
    <h1 class="mt-5 font-display text-4xl md:text-5xl max-w-2xl">
      Was bisher geschah
    </h1>
    <p class="mt-5 text-base-content/70 leading-relaxed max-w-2xl">
      Jede Werkstatt halten wir fest – locker und zum Nachlesen. So bleibt
      nichts verloren und auch wer nicht dabei war, ist im Bilde.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-16">
    {
      protokolle.length > 0 ? (
        <div class="grid gap-5 md:grid-cols-2">
          {protokolle.map((p) => (
            <ProtokollCard href={`/protokolle/${p.id}`} {...p.data} />
          ))}
        </div>
      ) : (
        <div class="card bg-base-100 border border-base-200 shadow-sm p-10 text-center">
          <p class="text-4xl">📝</p>
          <p class="mt-3 text-base-content/70">Die erste Nachlese folgt in Kürze.</p>
        </div>
      )
    }
  </section>
</Base>
