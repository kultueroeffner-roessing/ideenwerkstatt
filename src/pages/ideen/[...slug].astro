---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import StatusBadge from "../../components/StatusBadge.astro";

export async function getStaticPaths() {
  const ideen = await getCollection("ideen");
  return ideen.map((i) => ({
    params: { slug: i.id },
    props: { eintrag: i },
  }));
}

const { eintrag } = Astro.props;
const { Content } = await render(eintrag);
const d = eintrag.data;
const datumStr = d.datum?.toLocaleDateString("de-DE", {
  day: "2-digit",
  month: "long",
  year: "numeric",
});
---

<Base title={d.titel} description={d.pitch}>
  <article class="mx-auto max-w-3xl px-5 pt-12 pb-8">
    <a
      href="/ideen"
      class="inline-flex items-center gap-1 text-sm font-semibold text-primary hover:gap-2 transition-all"
    >
      <span aria-hidden="true">←</span> Zum Ideenbuch
    </a>

    <div class="mt-6 flex items-center gap-4">
      <span
        class="inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/15 text-4xl"
        aria-hidden="true">{d.emoji}</span
      >
      <StatusBadge status={d.status} />
    </div>

    <h1 class="mt-5 font-display text-4xl md:text-5xl leading-tight">
      {d.titel}
    </h1>
    <p class="mt-4 text-lg text-base-content/70 leading-relaxed">{d.pitch}</p>

    <div class="mt-5 flex flex-wrap items-center gap-2 text-sm text-base-content/60">
      <span class="badge badge-soft badge-secondary font-semibold">
        {d.kategorie}
      </span>
      {d.eingebrachtVon && <span>· eingebracht von {d.eingebrachtVon}</span>}
      {datumStr && <span>· {datumStr}</span>}
    </div>
  </article>

  <div class="mx-auto max-w-3xl px-5 pb-12">
    <div
      class="prose prose-lg max-w-none prose-headings:font-display prose-headings:text-base-content prose-strong:text-base-content prose-a:text-primary"
    >
      <Content />
    </div>
  </div>

  <div class="mx-auto max-w-3xl px-5 pb-20">
    <div class="card bg-warning/20 p-6 md:p-8 text-center">
      <p class="text-base-content/80">
        Du möchtest bei dieser Idee mitmachen oder hast etwas beizutragen?
      </p>
      <a href="/#termin" class="btn btn-primary rounded-full mt-4 mx-auto shadow-md">
        Komm zur nächsten Werkstatt
      </a>
    </div>
  </div>
</Base>
