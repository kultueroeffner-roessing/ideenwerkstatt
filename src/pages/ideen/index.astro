---
import { getCollection } from "astro:content";
import { ideaStatus } from "../../content.config";
import Base from "../../layouts/Base.astro";
import IdeaCard from "../../components/IdeaCard.astro";
import { meta } from "../../lib/status";

const alle = await getCollection("ideen");

// nach Status gruppieren, in der definierten Reihenfolge
const gruppen = ideaStatus
  .map((status) => ({
    status,
    info: meta(status),
    ideen: alle
      .filter((i) => i.data.status === status)
      .sort((a, b) => a.data.titel.localeCompare(b.data.titel, "de")),
  }))
  .filter((g) => g.ideen.length > 0);
---

<Base
  title="Ideen & Pitches"
  description="Das öffentliche Ideenbuch der Zukunftswerkstatt Rössing – gesammelte Ideen und ihr Umsetzungsstand."
>
  <section class="mx-auto max-w-6xl px-5 pt-14 pb-10">
    <span class="badge badge-soft badge-accent badge-lg gap-2 font-bold">
      💡 Unser öffentliches Ideenbuch
    </span>
    <h1 class="mt-5 font-display text-4xl md:text-5xl max-w-2xl">
      Ideen & Pitches aus dem Dorf
    </h1>
    <p class="mt-5 text-base-content/70 leading-relaxed max-w-2xl">
      Hier sammeln wir alles, was in den Werkstätten zusammenkommt – von der
      spontanen Idee bis zum fertigen Projekt. So sieht jede:r, woran wir
      gerade arbeiten und was schon Wirklichkeit geworden ist.
    </p>
  </section>

  <!-- Status-Legende -->
  <section class="mx-auto max-w-6xl px-5 pb-10">
    <div class="flex flex-wrap gap-2">
      {
        ideaStatus.map((s) => {
          const m = meta(s);
          return (
            <span class:list={["badge", m.badge, "font-bold gap-1"]}>
              <span aria-hidden="true">{m.emoji}</span>
              {m.label}
            </span>
          );
        })
      }
    </div>
  </section>

  {
    gruppen.length === 0 ? (
      <section class="mx-auto max-w-6xl px-5 py-12">
        <div class="card bg-base-100 border border-base-200 shadow-sm p-10 text-center">
          <p class="text-4xl">🌱</p>
          <p class="mt-3 text-base-content/70">
            Noch keine Ideen erfasst – die erste Werkstatt füllt dieses Buch.
          </p>
        </div>
      </section>
    ) : (
      gruppen.map((g) => (
        <section class="mx-auto max-w-6xl px-5 py-8">
          <h2 class="font-display text-2xl mb-5 flex items-center gap-2">
            <span aria-hidden="true">{g.info.emoji}</span>
            {g.info.label}
            <span class="text-base font-body font-semibold text-base-content/50">
              ({g.ideen.length})
            </span>
          </h2>
          <div class="grid gap-5 md:grid-cols-3">
            {g.ideen.map((i) => (
              <IdeaCard {...i.data} />
            ))}
          </div>
        </section>
      ))
    )
  }

  <!-- Mitmach-Aufruf -->
  <section class="mx-auto max-w-6xl px-5 py-12">
    <div class="card bg-warning/20 p-8 md:p-10 text-center">
      <h2 class="font-display text-2xl md:text-3xl">
        Du hast eine Idee für Rössing?
      </h2>
      <p class="mt-3 text-base-content/70 max-w-xl mx-auto">
        Bring sie zur nächsten Werkstatt mit oder schick sie uns vorab. Jede
        Idee zählt – egal wie groß oder klein.
      </p>
      <a href="/#termin" class="btn btn-primary rounded-full mt-6 mx-auto shadow-md">
        Zum nächsten Termin
      </a>
    </div>
  </section>
</Base>
